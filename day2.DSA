#include <bits/stdc++.h>
using namespace std;

class solution{
    public:
    void bubbleSort(int arr[],int n){
      for(int i=n-1;i>=1;i--){
          bool isSorted=true;
      for(int j=0;j<=i;j++){
          if (arr[j]>arr[j+1]){
              int temp=arr[j];
              arr[j]=arr[j+1];
              arr[j+1]=temp;
              isSorted=false;
          }
      }
        if(isSorted)break;
      }
    }
